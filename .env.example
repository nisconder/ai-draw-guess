# ============================================
# AI Provider API Keys
# ============================================
# You need at least one API key to play.
# Configure keys for the providers you want to use.
# ============================================

# ZhipuAI (智谱AI) - Default provider
# Get key: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# DeepSeek - Best value, OpenAI-compatible
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Alibaba Qwen (通义千问) - Best Chinese language
# Get key: https://dashscope.aliyuncs.com/
QWEN_API_KEY=your_qwen_api_key_here

# Moonshot Kimi (月之暗面) - Strong reasoning
# Get key: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# OpenAI - Global standard
# Get key: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
