# ===========================================
# AI Draw Guess - API Provider Configuration
# ===========================================
# Configure at least ONE provider's API key.
# The game supports 5 providers — you can use any or all of them.
# Keys are read server-side only and never exposed to the frontend.
# ===========================================

# 1. ZhipuAI (智谱AI) — GLM-4-Flash, free tier available
# Get key: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# 2. DeepSeek — V4 Flash, best value pricing
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 3. Alibaba Qwen (通义千问) — Qwen Flash, cheapest option
# Get key: https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# 4. Moonshot Kimi (月之暗面) — Kimi, strong reasoning
# Get key: https://platform.moonshot.cn/
KIMI_API_KEY=

# 5. OpenAI — GPT-4o-mini, global standard
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
